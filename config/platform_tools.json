{
  "auto_detect": {
    "enabled": true,
    "fallback_platform": "windows"
  },
  "default_platform": "auto",
  "module_mapping": {
    "SkillTool": "skill_tool",
    "SearchCodebaseTool": "search_codebase_tool",
    "GlobTool": "glob_tool",
    "LsTool": "ls_tool",
    "GrepTool": "grep_tool",
    "ReadTool": "read_tool",
    "WebSearchTool": "web_search_tool",
    "WebFetchTool": "web_fetch_tool",
    "DeleteFileTool": "delete_file_tool",
    "SearchReplaceTool": "search_replace_tool",
    "WriteTool": "write_tool",
    "RunCommandTool": "run_command_tool",
    "CheckCommandStatusTool": "check_command_status_tool",
    "StopCommandTool": "stop_command_tool",
    "GetDiagnosticsTool": "get_diagnostics_tool",
    "TodoWriteTool": "todo_write_tool",
    "OpenPreviewTool": "open_preview_tool",
    "AskUserQuestionTool": "ask_user_question_tool",
    "WindowsLsTool": "windows_ls_tool",
    "WindowsGlobTool": "windows_glob_tool",
    "WindowsDeleteFileTool": "windows_delete_file_tool",
    "WindowsRunCommandTool": "windows_run_command_tool",
