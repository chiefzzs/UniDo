      "path_separator": "\\",
      "tool_mapping": {
        "ls": "WindowsLsTool",
        "glob": "WindowsGlobTool",
        "delete_file": "WindowsDeleteFileTool",
        "run_command": "WindowsRunCommandTool"
      },
      "common_tools": [
        "SkillTool",
        "SearchCodebaseTool",
        "GrepTool",
        "ReadTool",
        "WebSearchTool",
        "WebFetchTool",
        "SearchReplaceTool",
        "WriteTool",
        "CheckCommandStatusTool",
        "StopCommandTool",
        "GetDiagnosticsTool",
        "TodoWriteTool",
        "OpenPreviewTool",
        "AskUserQuestionTool"
      ]
    },
    "linux": {
      "name": "Linux",
      "command_shell": ["bash", "sh"],
      "path_separator": "/",
      "tool_mapping": {
        "ls": "LinuxLsTool",
        "glob": "LinuxGlobTool",
        "delete_file": "LinuxDeleteFileTool",
        "run_command": "LinuxRunCommandTool"
      },
      "common_tools": [
        "SkillTool",
        "SearchCodebaseTool",
        "GrepTool",
        "ReadTool",
        "WebSearchTool",
        "WebFetchTool",
        "SearchReplaceTool",
        "WriteTool",
        "CheckCommandStatusTool",
        "StopCommandTool",
        "GetDiagnosticsTool",
        "TodoWriteTool",
        "OpenPreviewTool",
        "AskUserQuestionTool"
      ]
    },
    "macos": {
      "name": "macOS",
      "command_shell": ["bash", "zsh"],
      "path_separator": "/",
      "tool_mapping": {
        "ls": "LinuxLsTool",
        "glob": "LinuxGlobTool",
        "delete_file": "LinuxDeleteFileTool",
        "run_command": "LinuxRunCommandTool"
      },
      "common_tools": [
        "SkillTool",
        "SearchCodebaseTool",
        "GrepTool",
        "ReadTool",
        "WebSearchTool",
        "WebFetchTool",
        "SearchReplaceTool",
        "WriteTool",
        "CheckCommandStatusTool",
        "StopCommandTool",
        "GetDiagnosticsTool",
        "TodoWriteTool",
        "OpenPreviewTool",
        "AskUserQuestionTool"
      ]
    }
  }
