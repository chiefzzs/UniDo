{
  "tool_id": "T09",
  "name": "DeleteFile",
  "category": "文件",
  "supported_os": ["windows", "linux", "macos"],
  "supported_terminals": [],
  "platform_aliases": {},
  "parameters": {
    "file_paths": {
      "type": "array",
      "items": {"type": "string"},
      "description": "要删除的文件路径列表。必须是绝对路径。",
