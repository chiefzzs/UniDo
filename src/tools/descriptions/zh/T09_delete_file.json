  "description_en": "Delete files from the filesystem. You can delete multiple files in one call. Must ensure files exist before deleting.",
  "examples_zh": [
    "删除单个文件: file_paths=[\"/path/to/file.txt\"]",
    "删除多个文件: file_paths=[\"/path/to/file1.txt\", \"/path/to/file2.txt\"]"
  ],
  "examples_en": [
    "Delete single file: file_paths=[\"/path/to/file.txt\"]",
    "Delete multiple files: file_paths=[\"/path/to/file1.txt\", \"/path/to/file2.txt\"]"
  ]
}
